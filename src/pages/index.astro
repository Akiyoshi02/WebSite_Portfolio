---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/sections/Hero.astro";
import About from "@/components/sections/About.astro";
import Skills from "@/components/sections/Skills.astro";
import Projects from "@/components/sections/Projects.astro";
import Experience from "@/components/sections/Experience.astro";
import Education from "@/components/sections/Education.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
import Writing from "@/components/sections/Writing.astro";
import Contact from "@/components/sections/Contact.astro";
import { getSiteConfig } from "@/config/site";
import { getEducationEntries, getWorkExperience } from "@/lib/content";

const site = await getSiteConfig();
const educationList = await getEducationEntries();
const workExperience = await getWorkExperience();
const currentWork = workExperience[0];

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.fullName ?? site.name,
  alternateName: site.name,
  url: site.url,
  jobTitle: site.role,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: site.location,
  },
  alumniOf: educationList.map((entry) => ({
    "@type": "EducationalOrganization",
    name: entry.institution,
  })),
  ...(currentWork && { worksFor: {
    "@type": "Organization",
    name: currentWork.company,
    ...(currentWork.url && { sameAs: currentWork.url }),
  } }),
  sameAs: [
    site.socials.github,
    site.socials.linkedin,
    site.socials.x,
    site.socials.instagram,
    site.socials.facebook,
    site.socials.mastodon,
    site.socials.youtube,
  ].filter(Boolean),
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale,
};
---

<Base jsonLd={[personJsonLd, websiteJsonLd]}>
  <Hero />
  <About />
  <Skills />
  <Projects />
  <Experience />
  <Education />
  <Testimonials />
  <Writing />
  <Contact />
</Base>

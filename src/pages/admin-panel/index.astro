---
import AdminApp from "@/components/admin/AdminApp";
import "@/styles/global.css";
import "@/styles/admin.css";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Panel - Portfolio</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
    <style>
      html,
      body {
        height: 100%;
        overflow: hidden;
      }
    </style>
    <script is:inline>
      (function () {
        var hash = window.location.hash.replace(/^#/, "");
        if (!hash) return;

        var params = new URLSearchParams(hash);
        var isRecoveryLink =
          params.get("type") === "recovery" ||
          params.has("access_token") ||
          params.has("refresh_token") ||
          params.has("error_description");

        if (isRecoveryLink) {
          window.location.replace("/admin-panel/reset-password" + window.location.hash);
        }
      })();
    </script>
  </head>
  <body class="admin-page">
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="cursor-ring" aria-hidden="true"></div>
    <AdminApp client:only="react" />
    <script>
      import "@/scripts/admin-cursor.ts";
    </script>
  </body>
</html>

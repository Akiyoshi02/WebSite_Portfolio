---
import Base from "@/layouts/Base.astro";
import { getSiteConfig } from "@/config/site";
import { getNowPage } from "@/lib/content";

const site = await getSiteConfig();
const now = await getNowPage();

function formatDate(input: string) {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(new Date(input));
}
---

<Base
  title="Now"
  description={`What ${site.name} is focused on right now.`}
  hidePreloader
>
  <section class="section">
    <div class="container" style="max-width:680px;margin-inline:auto">
      <div class="section-heading">
        <div class="section-kicker">// Now</div>
        <h2>What I&apos;m doing now</h2>
        <p>
          A <a href="https://nownownow.com/about" style="color:var(--accent-1)">/now</a> page:
          a snapshot of current focus, intentionally short and updated regularly.
        </p>
      </div>

      <div class="prose">
        <p>
          <strong>Location.</strong> {now.location}.
        </p>
        <p>
          <strong>Working on.</strong> {now.working_on}
        </p>
        <p>
          <strong>Studying.</strong> {now.studying}
        </p>
        <p>
          <strong>Learning.</strong> {now.learning}
        </p>
        <p>
          <strong>Open to.</strong> {now.open_to}
        </p>
        <p style="margin-top:32px;color:var(--text-muted);font-family:var(--font-mono);font-size:.85rem">
          Last updated {formatDate(now.last_updated)}.
        </p>
      </div>
    </div>
  </section>
</Base>

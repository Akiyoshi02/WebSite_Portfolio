---
import { getBlogPosts } from "@/lib/content";

const latest = (await getBlogPosts()).slice(0, 3);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
}

function readingTime(text: string) {
  const words = text.split(/\s+/).filter(Boolean).length;
  // 238 wpm is closer to average adult reading speed (was 220)
  return Math.max(1, Math.round(words / 238));
}
---

<section class="section" id="writing" data-animate>
  <div class="container">
    <div class="section-heading">
      <div class="section-kicker">// 07. Writing</div>
      <h2>Latest Thoughts</h2>
      <p>Notes on software, systems, and the craft of building.</p>
    </div>

    <div class="blog-grid">
      {latest.map((post) => {
        const minutes = readingTime(post.body);
        return (
          <article class="blog-card glass">
            <div>
              {post.cover_url && (
                <img
                  class="blog-card-cover"
                  src={post.cover_url}
                  alt={post.cover_alt ?? `${post.title} cover image`}
                  loading="lazy"
                  decoding="async"
                />
              )}
              {post.tags[0] && <span class="category-badge">{post.tags[0]}</span>}
              <h3 style="margin-top:16px">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h3>
              <p style="margin-top:12px">{post.description}</p>
            </div>
            <div class="project-title-row">
              <span class="section-kicker">
                {minutes} min / {formatDate(new Date(post.pub_date))}
              </span>
              <a class="interactive" href={`/blog/${post.slug}`}>Read More</a>
            </div>
          </article>
        );
      })}
    </div>

    <div style="margin-top:26px">
      <a class="btn btn-secondary interactive" href="/blog">View All Posts</a>
    </div>
  </div>
</section>

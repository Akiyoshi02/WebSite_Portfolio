---
import { getWorkExperience } from "@/lib/content";
import { renderMarkdown } from "@/lib/markdown";

const work = await getWorkExperience();
---

<section class="section" id="experience" data-animate>
  <div class="container">
    <div class="section-heading">
      <div class="section-kicker">// 04. Experience</div>
      <h2>A timeline of practice, shipping, and growth.</h2>
      <p>
        Applied work and production-minded delivery, building and maintaining software
        in real team environments.
      </p>
    </div>

    <div class="timeline" id="timeline">
      {work.map((entry) => {
        const bodyHtml = renderMarkdown(entry.body);
        const logoSrc = entry.logo_url?.trim() || "/images/company-placeholder.svg";
        const hasCustomLogo = Boolean(entry.logo_url?.trim());
        return (
          <article class="timeline-item">
            <span class="timeline-dot" aria-hidden="true"></span>
            <div class="timeline-card glass">
              <div class="company-row">
                <span class="company-logo">
                  <img
                    src={logoSrc}
                    alt={hasCustomLogo ? `${entry.company} logo` : "Company logo placeholder"}
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                    class:list={[!hasCustomLogo && "is-placeholder"]}
                  />
                </span>
                {entry.url ? (
                  <a class="interactive" href={entry.url} rel="noopener">{entry.company}</a>
                ) : (
                  <span>{entry.company}</span>
                )}
              </div>
              <h3>{entry.title}</h3>
              <span class="date-badge">{entry.date_range}</span>
              <ul>
                {entry.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
              <div class="tag-row">
                {entry.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              {entry.body && <div class="timeline-body prose" set:html={bodyHtml} />}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

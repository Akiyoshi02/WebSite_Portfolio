---
import { getSiteConfig } from "@/config/site";
import { getAboutContent } from "@/lib/content";

const site = await getSiteConfig();
const about = await getAboutContent();
const portraitSrc = about.profile_image_url?.trim() || "/images/profile-placeholder.svg";
const hasCustomPortrait = Boolean(about.profile_image_url?.trim());
---

<section class="section" id="about" data-animate>
  <div class="container about-grid">
    <div class="about-copy">
      <div class="section-kicker">// 01. About Me</div>
      <h2>Engineer with an eye for systems and detail.</h2>

      <p>{about.bio_paragraph_1}</p>
      <p>{about.bio_paragraph_2}</p>

      <div class="chip-row">
        {about.chips.map((chip) => (
          <span class="chip">{chip}</span>
        ))}
      </div>

      <div class="stats-grid" id="stats-grid">
        <div class="stat-card">
          <span class="stat-number" data-count={about.stat_featured_projects}>0</span>
          <span class="stat-label">Featured Projects</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-count={about.stat_years_coding}>0</span>
          <span class="stat-label">Years Coding</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-count={about.stat_technologies}>0</span>
          <span class="stat-label">Technologies</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-count={about.stat_skill_domains}>0</span>
          <span class="stat-label">Skill Domains</span>
        </div>
      </div>
    </div>

    <div class="portrait-wrap">
      <div class="portrait-frame image-hover">
        <span class="corner-accent one" aria-hidden="true"></span>
        <span class="corner-accent two" aria-hidden="true"></span>
        <div class="portrait">
          <img
            src={portraitSrc}
            alt={hasCustomPortrait ? `Portrait of ${site.name}` : "Profile image placeholder"}
            loading="eager"
            decoding="async"
            referrerpolicy="no-referrer"
            class:list={[!hasCustomPortrait && "is-placeholder"]}
          />
        </div>
      </div>
      <div class="code-card glass">
        <div class="dot-row" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div><span class="token-key">function</span> <span class="token-name">helloWorld</span>() &#123;</div>
        <div>&nbsp;&nbsp;<span class="token-key">const</span> craft = <span class="token-string">"software"</span>;</div>
        <div>&nbsp;&nbsp;<span class="token-key">return</span> <span class="token-fn">ship</span>(craft);</div>
        <div>&#125;</div>
      </div>
    </div>
  </div>
</section>

---
import { getEducationEntries } from "@/lib/content";

const educationList = await getEducationEntries();
---

<section class="section" id="education" data-animate>
  <div class="container">
    <div class="section-heading">
      <div class="section-kicker">// 05. Education</div>
      <h2>Academic path into software engineering.</h2>
      <p>
        From secondary school in Sri Lanka through foundation and undergraduate study in the UK,
        building toward a full software engineering degree.
      </p>
    </div>

    <div class="education-stack">
      {educationList.map((entry) => (
        <article class="education-card glass">
          <div>
            <span class="date-badge">{entry.period}</span>
            <h3>{entry.institution}</h3>
            <p>
              <strong>{entry.degree}</strong>
            </p>
            <div class="tag-row" style="margin-top:18px">
              {entry.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          {entry.logo_path && (
            <figure class={`education-logo education-logo--${entry.logo_type}`}>
              <img
                src={entry.logo_path}
                alt={entry.institution}
                width={entry.logo_width}
                height={entry.logo_height}
                loading="lazy"
                decoding="async"
              />
            </figure>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

---
---

<section class="section" id="education" data-animate>
  <div class="container">
    <div class="section-heading">
      <div class="section-kicker">// 05. Education</div>
      <h2>Academic path into software engineering.</h2>
      <p>
        From secondary school in Sri Lanka through foundation and undergraduate study in the UK,
        building toward a full software engineering degree.
      </p>
    </div>

    <div class="education-stack">
      <article class="education-card glass">
        <div>
          <span class="date-badge">2008 – 2022</span>
          <h3>Thurstan College, Sri Lanka</h3>
          <p>
            <strong>G.C.E. Ordinary Level</strong>
          </p>
          <div class="tag-row" style="margin-top:18px">
            <span class="tag">G.C.E. O/L</span>
            <span class="tag">Secondary Education</span>
            <span class="tag">Academic Foundation</span>
            <span class="tag">Leadership</span>
            <span class="tag">Teamwork</span>
          </div>
        </div>
        <figure class="education-logo education-logo--crest">
          <img
            src="/logos/thurstan.png"
            alt="Thurstan College"
            width="1254"
            height="1254"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </article>

      <article class="education-card glass">
        <div>
          <span class="date-badge">2022 – 2025</span>
          <h3>SLIIT City University, Sri Lanka</h3>
          <p>
            <strong>Foundation Certificate + HND in Information Technology</strong>
          </p>
          <div class="tag-row" style="margin-top:18px">
            <span class="tag">Programming</span>
            <span class="tag">Web Dev</span>
            <span class="tag">Databases</span>
            <span class="tag">Server-side</span>
            <span class="tag">Dean&apos;s List 2024</span>
          </div>
        </div>
        <figure class="education-logo education-logo--wide">
          <img
            src="/logos/sliit.png"
            alt="SLIIT City University"
            width="864"
            height="466"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </article>

      <article class="education-card glass">
        <div>
          <span class="date-badge">2025 – Present</span>
          <h3>University of Bedfordshire, UK</h3>
          <p>
            <strong>BSc (Hons) Software Engineering</strong>
          </p>
          <div class="tag-row" style="margin-top:18px">
            <span class="tag">Software Engineering</span>
            <span class="tag">Software Development</span>
            <span class="tag">Databases</span>
            <span class="tag">Project Execution</span>
          </div>
        </div>
        <figure class="education-logo education-logo--wide">
          <img
            src="/logos/bedfordshire.png"
            alt="University of Bedfordshire"
            width="1234"
            height="492"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </article>
    </div>
  </div>
</section>

---
import Icon from "./Icon.astro";
import type { ProjectRow } from "@/types/supabase";

interface Props {
  project: ProjectRow;
}

const { project } = Astro.props;
const safeKey = project.title.replace(/\W/g, "");
const localHref = `/projects/${project.slug}`;
---

<article
  class={`project-card glass ${project.wide ? "is-wide" : ""}`}
  data-category={project.category}
>
  <div class="project-media">
    {project.featured && <div class="ribbon">Featured</div>}

    <svg
      class="project-visual image-hover"
      viewBox="0 0 760 420"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label={`${project.title} project mockup`}
    >
        <defs>
          <linearGradient id={`g-${safeKey}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color={project.theme_from} />
            <stop offset="1" stop-color={project.theme_to} />
          </linearGradient>
          <pattern id={`p-${safeKey}`} width="34" height="34" patternUnits="userSpaceOnUse">
            <path d="M34 0H0v34" fill="none" stroke="white" stroke-opacity=".08" />
          </pattern>
        </defs>
        <rect width="760" height="420" fill="#0d1117" />
        <rect width="760" height="420" fill={`url(#g-${safeKey})`} opacity=".22" />
        <rect width="760" height="420" fill={`url(#p-${safeKey})`} />
        <rect
          x="70"
          y="70"
          width="620"
          height="280"
          rx="18"
          fill="rgba(255,255,255,.08)"
          stroke="rgba(255,255,255,.18)"
        />
        <rect x="100" y="105" width="220" height="22" rx="8" fill="white" opacity=".75" />
        <rect x="100" y="145" width="440" height="14" rx="7" fill="white" opacity=".25" />
        <rect x="100" y="174" width="370" height="14" rx="7" fill="white" opacity=".16" />
        <rect x="100" y="225" width="140" height="72" rx="14" fill={project.theme_from} opacity=".76" />
        <rect x="260" y="225" width="140" height="72" rx="14" fill={project.theme_to} opacity=".72" />
        <path
          d="M445 292c39-100 82-128 146-84 24 17 43 25 71 15"
          fill="none"
          stroke={project.theme_from}
          stroke-width="8"
          stroke-linecap="round"
        />
        <text
          x="100"
          y="330"
          fill="white"
          opacity=".82"
          font-family="JetBrains Mono, monospace"
          font-size="20"
        >
          {project.title}
        </text>
    </svg>

    <div class="project-overlay">
      <a class="btn btn-primary interactive" href={localHref} aria-label={`View ${project.title} case study`}>
        Case Study
      </a>
      {project.link_live && (
        <a
          class="btn btn-secondary interactive"
          href={project.link_live}
          aria-label={`Open live ${project.title}`}
          rel="noopener noreferrer" target="_blank"
        >
          Live
        </a>
      )}
      {project.link_repo && (
        <a
          class="btn btn-secondary interactive"
          href={project.link_repo}
          aria-label={`${project.title} source code`}
          rel="noopener noreferrer" target="_blank"
        >
          GitHub
        </a>
      )}
    </div>
  </div>

  <div class="project-body">
    <div class="project-title-row">
      <h3><a href={localHref}>{project.title}</a></h3>
      <div style="display:flex;gap:8px">
        {project.link_live && (
          <a class="icon-btn interactive" href={project.link_live} aria-label={`Open ${project.title}`} rel="noopener noreferrer" target="_blank">
            <Icon name="external" />
          </a>
        )}
        {project.link_repo && (
          <a class="icon-btn interactive" href={project.link_repo} aria-label={`${project.title} source code`} rel="noopener noreferrer" target="_blank">
            <Icon name="github" />
          </a>
        )}
      </div>
    </div>
    <p class="project-desc">{project.description}</p>
    <div class="tag-row">
      {project.stack.map((tag) => (
        <span class="tech-pill">{tag}</span>
      ))}
    </div>
    <div class="project-stats">
      {typeof project.stars === "number" && <span>* {project.stars}</span>}
      {typeof project.forks === "number" && <span>Forks {project.forks}</span>}
      <span>{project.year}</span>
    </div>
  </div>
</article>

---
/**
 * Inline SVG icon set. Keeping these inline avoids an extra HTTP request
 * and lets icons inherit `currentColor` for theming.
 */
type IconName =
  | "github"
  | "linkedin"
  | "x"
  | "facebook"
  | "instagram"
  | "mastodon"
  | "youtube"
  | "mail"
  | "external"
  | "chevron-up"
  | "chevron-down"
  | "chevron-left"
  | "chevron-right"
  | "sun"
  | "moon"
  | "menu"
  | "close"
  | "copy"
  | "check"
  | "map-pin"
  | "terminal"
  | "download";

interface Props {
  name: IconName;
  class?: string;
  /** Pass true on decorative icons; otherwise provide an aria-label on the wrapper. */
  decorative?: boolean;
}

const { name, class: className = "icon", decorative = true } = Astro.props;
const ariaHidden = decorative ? "true" : undefined;
---

{name === "github" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>
    <path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.6 4.3 18.6 4.6 18.6 4.6c.7 1.6.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.4v3.6c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" />
  </svg>
)}
{name === "linkedin" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>

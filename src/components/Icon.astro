---
/**
 * Inline SVG icon set. Keeping these inline avoids an extra HTTP request
 * and lets icons inherit `currentColor` for theming.
 */
type IconName =
  | "github"
  | "linkedin"
  | "x"
  | "facebook"
  | "instagram"
  | "mail"
  | "external"
  | "chevron-up"
  | "chevron-down"
  | "chevron-left"
  | "chevron-right"
  | "sun"
  | "moon"
  | "menu"
  | "close"
  | "copy"
  | "check"
  | "map-pin"
  | "terminal";

interface Props {
  name: IconName;
  class?: string;
  /** Pass true on decorative icons; otherwise provide an aria-label on the wrapper. */
  decorative?: boolean;
}

const { name, class: className = "icon", decorative = true } = Astro.props;
const ariaHidden = decorative ? "true" : undefined;
---

{name === "github" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>
    <path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.6 4.3 18.6 4.6 18.6 4.6c.7 1.6.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.4v3.6c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" />
  </svg>
)}
{name === "linkedin" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>
    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.23 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.46c.98 0 1.77-.78 1.77-1.74V1.74C24 .78 23.2 0 22.23 0Z" />
  </svg>
)}
{name === "x" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>
    <path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.42l-5.82-7.6-6.65 7.6H.43l8.6-9.83L0 1.15h7.61l5.25 6.95 6.04-6.95Zm-1.29 19.5h2.04L6.5 3.23H4.31l13.3 17.42Z" />
  </svg>
)}
{name === "facebook" && (
  <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden={ariaHidden}>
    <path d="M22.675 0H1.325C.593 0 0 .593 0 1.326v21.348C0 23.408.593 24 1.325 24h11.49v-9.294H9.692v-3.622h3.123V8.413c0-3.099 1.894-4.785 4.659-4.785 1.325 0 2.464.099 2.796.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116C23.407 24 24 23.408 24 22.674V1.326C24 .593 23.407 0 22.675 0Z" />
  </svg>
)}
{name === "instagram" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2" />
    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
    <circle cx="17.5" cy="6.5" r="1.25" fill="currentColor" stroke="none" />
  </svg>
)}
{name === "mail" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="2" />
    <path d="m22 8-10 6L2 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "external" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M14 3h7v7M21 3l-9 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M10 5H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}
{name === "chevron-up" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="m18 15-6-6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "chevron-down" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "chevron-left" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M15 18 9 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "chevron-right" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "sun" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.66-5.66 1.41-1.41M4.93 19.07l1.41-1.41m0-11.32L4.93 4.93m14.14 14.14-1.41-1.41M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}
{name === "moon" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path
      d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
)}
{name === "menu" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}
{name === "close" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}
{name === "copy" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M8 8h11v11H8z" stroke="currentColor" stroke-width="2" />
    <path d="M5 16H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h11a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="2" />
  </svg>
)}
{name === "check" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="m5 12 4 4L19 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
{name === "map-pin" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="M12 22s7-6.1 7-13A7 7 0 1 0 5 9c0 6.9 7 13 7 13Z" stroke="currentColor" stroke-width="2" />
    <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="2" />
  </svg>
)}
{name === "terminal" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden={ariaHidden}>
    <path d="m4 7 5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M11 17h9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

---
// Boot-up terminal preloader. Removes itself after the first paint
// (or immediately if the user prefers reduced motion).
---

<div class="preloader" id="preloader" role="status" aria-live="polite">
  <div class="boot-terminal" aria-label="Portfolio loading sequence">
    <div class="boot-line" id="boot-line-0"></div>
    <div class="boot-line" id="boot-line-1"></div>
    <div class="boot-line" id="boot-line-2"></div>
    <div class="boot-line" id="boot-line-3"></div>
    <span class="boot-cursor" aria-hidden="true"></span>
  </div>
</div>

---
import "leaflet/dist/leaflet.css";
import { getSiteConfig } from "@/config/site";

const site = await getSiteConfig();
---

<div class="map-panel glass contact-map-shell">
  <div
    id="contact-map"
    class="contact-map"
    role="application"
    aria-label={`Interactive map of the approximate ${site.location} area. Drag to pan; click the map to enable scroll zoom.`}
    tabindex="0"
  ></div>
  <p class="contact-map-caption">
    <span class="contact-map-hint">Click map to zoom with scroll - </span>
    Approximate area - {site.location}
  </p>
</div>

<script>
  import "@/scripts/contact-map.ts";
</script>

---
import "leaflet/dist/leaflet.css";
---

<div class="map-panel glass contact-map-shell">
  <div
    id="contact-map"
    class="contact-map"
    role="application"
    aria-label="Interactive map of the approximate Ragama area in Sri Lanka. Drag to pan; click the map to enable scroll zoom."
    tabindex="0"
  ></div>
  <p class="contact-map-caption">
    <span class="contact-map-hint">Click map to zoom with scroll · </span>
    Approximate area · Ragama, Sri Lanka
  </p>
</div>

<script>
  import "@/scripts/contact-map.ts";
</script>

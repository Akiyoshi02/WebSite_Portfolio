---
import Base from "./Base.astro";
import { site } from "@/config/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: data.title,
  description: data.description,
  inLanguage: site.locale,
  dateCreated: `${data.year}-01-01`,
  url: new URL(Astro.url.pathname, site.url).toString(),
  creator: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  keywords: data.stack.join(", "),
  ...(data.links.repo && { codeRepository: data.links.repo }),
  ...(data.links.live && { sameAs: [data.links.live] }),
};
---

<Base
  title={data.title}
  description={data.tagline ?? data.description}
  type="article"
  hidePreloader
  jsonLd={jsonLd}
>
  <article class="section">
    <div class="container" style="max-width:880px;margin-inline:auto">
      <a href="/#projects" class="section-kicker interactive" style="display:inline-block;margin-bottom:18px">
        ← Back to projects
      </a>

      <header style="display:grid;gap:14px;margin-bottom:28px">
        <span class="date-badge" style="width:fit-content">
          {data.category.toUpperCase()} · {data.year}
        </span>
        <h1 style="font-family:var(--font-display);font-size:clamp(2.4rem,5vw,3.6rem);line-height:1.05">
          {data.title}
        </h1>
        <p style="font-size:1.15rem;color:var(--text-soft);max-width:65ch">
          {data.tagline}
        </p>
        <div class="tag-row">
          {data.stack.map((tag) => (
            <span class="tech-pill">{tag}</span>
          ))}
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:6px">
          {data.links.live && (
            <a class="btn btn-primary interactive" href={data.links.live} rel="noopener">
              View live →
            </a>
          )}
          {data.links.repo && (
            <a class="btn btn-secondary interactive" href={data.links.repo} rel="noopener">
              Source code
            </a>
          )}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

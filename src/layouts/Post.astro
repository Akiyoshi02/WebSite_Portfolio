---
import Base from "./Base.astro";
import { site } from "@/config/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { data } = post;

const url = new URL(Astro.url.pathname, site.url).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  ...(data.updatedDate && { dateModified: data.updatedDate.toISOString() }),
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  author: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  publisher: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  inLanguage: site.locale,
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<Base
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={data.pubDate.toISOString()}
  modifiedTime={data.updatedDate?.toISOString()}
  hidePreloader
  jsonLd={jsonLd}
>
  <article class="section">
    <div class="container" style="max-width:780px;margin-inline:auto">
      <a href="/blog" class="section-kicker interactive" style="display:inline-block;margin-bottom:18px">
        ← All posts
      </a>

      <header style="display:grid;gap:14px;margin-bottom:28px">
        <h1 style="font-family:var(--font-display);font-size:clamp(2.2rem,4.6vw,3.2rem);line-height:1.1">
          {data.title}
        </h1>
        <p style="font-size:1.05rem;color:var(--text-soft);max-width:65ch">
          {data.description}
        </p>
        <div style="display:flex;gap:16px;flex-wrap:wrap;color:var(--text-muted);font-family:var(--font-mono);font-size:.85rem">
          <time datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          {data.updatedDate && (
            <span>· Updated {formatDate(data.updatedDate)}</span>
          )}
        </div>
        {data.tags.length > 0 && (
          <div class="tag-row">
            {data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

---
import Base from "./Base.astro";
import { getSiteConfig } from "@/config/site";
import type { BlogPostRow } from "@/types/supabase";

interface Props {
  post: BlogPostRow;
}

const site = await getSiteConfig();
const { post } = Astro.props;
const url = new URL(Astro.url.pathname, site.url).toString();
const pubDate = new Date(post.pub_date);
const updatedDate = post.updated_date ? new Date(post.updated_date) : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  author: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  publisher: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  inLanguage: site.locale,
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<Base
  title={post.title}
  description={post.description}
  image={post.cover_url ?? undefined}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
  hidePreloader
  jsonLd={jsonLd}
>
  <article class="section">
    <div class="container" style="max-width:780px;margin-inline:auto">
      <a href="/blog" class="section-kicker interactive" style="display:inline-block;margin-bottom:18px">
        All posts
      </a>

      <header style="display:grid;gap:14px;margin-bottom:28px">
        <h1 style="font-family:var(--font-display);font-size:clamp(2.2rem,4.6vw,3.2rem);line-height:1.1">
          {post.title}
        </h1>
        <p style="font-size:1.05rem;color:var(--text-soft);max-width:65ch">
          {post.description}
        </p>
        <div style="display:flex;gap:16px;flex-wrap:wrap;color:var(--text-muted);font-family:var(--font-mono);font-size:.85rem">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {updatedDate && <span>/ Updated {formatDate(updatedDate)}</span>}
        </div>
        {post.tags.length > 0 && (
          <div class="tag-row">
            {post.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        {post.cover_url && (
          <img
            class="post-cover"
            src={post.cover_url}
            alt={post.cover_alt ?? `${post.title} cover image`}
            loading="eager"
            decoding="async"
          />
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

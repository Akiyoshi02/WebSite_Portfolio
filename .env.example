# Canonical production URL (set in Netlify → Site configuration → Environment variables).
SITE_URL=https://akiyoshiyapa.netlify.app

# Formspree form ID from https://formspree.io/ (the part after /f/ in your form URL).
PUBLIC_FORMSPREE_FORM_ID=

# Optional: build-time token for live GitHub contribution heatmap.
GH_TOKEN=

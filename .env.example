# Canonical production URL (set in Netlify environment variables).
SITE_URL=https://akiyoshiyapa.netlify.app
SITE_NAME=Akiyoshi Yapa
SITE_TAGLINE=Software Engineer & Full-Stack Developer

# Optional: build-time token for live GitHub contribution heatmap.
GH_TOKEN=

# --- SMTP (Netlify Functions only - set in Netlify, not exposed to the browser) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=portfolio@yourdomain.com
CONTACT_TO_EMAIL=akiyoshiyapa@gmail.com

# --- Supabase content CMS ---
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PUBLIC_ADMIN_EMAILS=akiyoshiyapa@gmail.com
ADMIN_EMAILS=akiyoshiyapa@gmail.com

# --- Netlify rebuild hook (server-side only; never prefix this with PUBLIC_) ---
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your-hook-id

{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@/*": ["src/*"]
    },
    "jsx": "preserve",
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "skipLibCheck": true
  }
}
